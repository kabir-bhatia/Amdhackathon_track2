# Copy to .env for local dev. NEVER bake .env into the Docker image or commit real keys.
# The container reads these purely from the runtime environment.

# --- Provider selection ---
# VISION_PROVIDER: stub | local_vlm | hosted
# LLM_PROVIDER:    stub | local_gemma | fireworks
VISION_PROVIDER=stub
LLM_PROVIDER=stub

# --- Frame sampling ---
# Max frames handed to the vision model per clip, and target sampling fps.
MAX_FRAMES=8
SAMPLE_FPS=1.0

# --- Local model IDs (GPU pod) ---
VLM_MODEL_ID=Qwen/Qwen2-VL-2B-Instruct
GEMMA_MODEL_ID=google/gemma-2-2b-it

# --- Fireworks (filled once the $50 coupon is redeemed) ---
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL_ID=
